{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(css|js|assets|fonts)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/workers/(.*)\\.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    },
    {
      "source": "/(.*)\\.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/compress-image",
      "destination": "/tools/compression/index.html"
    },
    {
      "source": "/compress-jpg",
      "destination": "/tools/compression/jpg.html"
    },
    {
      "source": "/compress-png",
      "destination": "/tools/compression/png.html"
    },
    {
      "source": "/convert-jpg-to-png",
      "destination": "/tools/conversion/jpg-to-png.html"
    },
    {
      "source": "/convert-png-to-jpg",
      "destination": "/tools/conversion/png-to-jpg.html"
    },
    {
      "source": "/convert-to-webp",
      "destination": "/tools/conversion/to-webp.html"
    },
    {
      "source": "/resize-image",
      "destination": "/tools/resize/index.html"
    },
    {
      "source": "/resize-for-instagram",
      "destination": "/tools/resize/instagram.html"
    },
    {
      "source": "/resize-for-facebook",
      "destination": "/tools/resize/facebook.html"
    },
    {
      "source": "/crop-image",
      "destination": "/tools/editor/crop.html"
    },
    {
      "source": "/rotate-image",
      "destination": "/tools/editor/rotate.html"
    },
    {
      "source": "/add-watermark",
      "destination": "/tools/editor/watermark.html"
    },
    {
      "source": "/bulk-compress",
      "destination": "/tools/bulk-tools/compress.html"
    },
    {
      "source": "/bulk-convert",
      "destination": "/tools/bulk-tools/convert.html"
    },
    {
      "source": "/merge-pdf",
      "destination": "/tools/pdf-tools/merge.html"
    },
    {
      "source": "/split-pdf",
      "destination": "/tools/pdf-tools/split.html"
    },
    {
      "source": "/compress-pdf",
      "destination": "/tools/pdf-tools/compress.html"
    },
    {
      "source": "/pdf-to-jpg",
      "destination": "/tools/pdf-tools/pdf-to-jpg.html"
    },
    {
      "source": "/jpg-to-pdf",
      "destination": "/tools/pdf-tools/jpg-to-pdf.html"
    },
    {
      "source": "/ai-background-remover",
      "destination": "/tools/ai-tools/background-remover.html"
    },
    {
      "source": "/ai-upscaler",
      "destination": "/tools/ai-tools/upscaler.html"
    }
  ]
}
