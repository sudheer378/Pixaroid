    90	        {
    91	          "key": "Cache-Control",
    92	          "value": "public, max-age=31536000, immutable"
    93	        }
    94	      ]
    95	    },
    96	    {
    97	      "source": "/(.*)",
    98	      "headers": [
    99	        {
   100	          "key": "X-Content-Type-Options",
   101	          "value": "nosniff"
   102	        },
   103	        {
   104	          "key": "Referrer-Policy",
   105	          "value": "strict-origin-when-cross-origin"
   106	        },
   107	        {
